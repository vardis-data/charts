<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vardis Helm Charts</title>
    <style>
        :root {
            --bg: #0d1117;
            --card-bg: #161b22;
            --border: #30363d;
            --text: #c9d1d9;
            --text-muted: #8b949e;
            --accent: #58a6ff;
            --accent-hover: #79b8ff;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            padding: 2rem;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
        }
        header {
            text-align: center;
            margin-bottom: 3rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--border);
        }
        h1 {
            font-size: 2.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }
        .subtitle {
            color: var(--text-muted);
            font-size: 1.1rem;
        }
        .usage {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }
        .usage h2 {
            font-size: 1rem;
            margin-bottom: 1rem;
            color: var(--text-muted);
        }
        code {
            background: var(--bg);
            padding: 0.75rem 1rem;
            border-radius: 6px;
            display: block;
            font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
            font-size: 0.9rem;
            overflow-x: auto;
        }
        .charts {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .chart {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.5rem;
            transition: border-color 0.2s;
        }
        .chart:hover {
            border-color: var(--accent);
        }
        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 0.75rem;
        }
        .chart-name {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--accent);
        }
        .chart-versions {
            display: flex;
            gap: 0.5rem;
        }
        .badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-family: monospace;
        }
        .badge-version {
            background: #238636;
            color: #fff;
        }
        .badge-app {
            background: #1f6feb;
            color: #fff;
        }
        .badge-keyword {
            background: var(--border);
            color: var(--text);
        }
        .chart-keywords {
            display: flex;
            flex-wrap: wrap;
            gap: 0.25rem;
            margin-top: 0.75rem;
        }
        .chart-description {
            color: var(--text-muted);
            font-size: 0.95rem;
        }
        footer {
            text-align: center;
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        footer a {
            color: var(--accent);
            text-decoration: none;
        }
        footer a:hover {
            text-decoration: underline;
        }
        @media (max-width: 600px) {
            body {
                padding: 1rem;
            }
            h1 {
                font-size: 1.75rem;
            }
            .chart-header {
                flex-direction: column;
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Vardis Helm Charts</h1>
            <p class="subtitle">Helm chart repository for Vardis infrastructure</p>
        </header>

        <div class="usage">
            <h2>Usage</h2>
            <code>helm repo add vardis https://vardis-data.github.io/charts</code>
        </div>

        <div class="charts">
            {% for chart in charts %}
            <div class="chart">
                <div class="chart-header">
                    <span class="chart-name">{{ chart.name }}</span>
                    <div class="chart-versions">
                        <span class="badge badge-version">{{ chart.version }}</span>
                        {% if chart.app_version %}
                        <span class="badge badge-app">{{ chart.app_version }}</span>
                        {% endif %}
                    </div>
                </div>
                {% if chart.description %}
                <p class="chart-description">{{ chart.description }}</p>
                {% endif %}
                {% if chart.keywords %}
                <div class="chart-keywords">
                    {% for keyword in chart.keywords %}
                    <span class="badge badge-keyword">{{ keyword }}</span>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <footer>
            <p>
                <a href="https://github.com/vardis/charts">GitHub Repository</a>
            </p>
        </footer>
    </div>
</body>
</html>
